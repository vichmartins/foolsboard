# Example foolsboard configuration.
#
# The installer generates the real file at /etc/foolsboard/foolsboard.env with a
# random JWT_SECRET on first install. This copy documents the available knobs.

# Where the app listens. By default it serves the SPA + API + WebSocket + media
# itself (no other software needed). To run behind a reverse proxy, set
# FOOLSBOARD_HOST=127.0.0.1 and point the proxy at http://127.0.0.1:9534.
FOOLSBOARD_HOST=0.0.0.0
FOOLSBOARD_PORT=9534

# Built frontend, served by the app.
STATIC_DIR=/opt/foolsboard/frontend/dist

# Data.
DATABASE_URL=sqlite:////var/lib/foolsboard/foolsboard.db
STORAGE_LOCAL_DIR=/var/lib/foolsboard/storage
JWT_SECRET=change-me

# --- Optional: Postgres instead of SQLite ---
#   /opt/foolsboard/venv/bin/pip install -r /opt/foolsboard/backend/requirements-postgres.txt
#   DATABASE_URL=postgresql+psycopg://foolsboard:PASSWORD@localhost:5432/foolsboard
