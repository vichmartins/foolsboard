# Copy to .env and adjust. The app reads these at startup.

# --- Database ---------------------------------------------------------------
# SQLite (default, zero-install dev):
DATABASE_URL=sqlite:///./foolsboard.db
# Postgres -- requires: pip install -r requirements-postgres.txt
# (use 127.0.0.1 rather than localhost to avoid the IPv6 ::1 auth path)
# DATABASE_URL=postgresql+psycopg://foolsboard:CHANGEME@127.0.0.1:5432/foolsboard
# MySQL/MariaDB example:
# DATABASE_URL=mysql+pymysql://foolsboard:CHANGEME@127.0.0.1:3306/foolsboard

# --- Media storage ----------------------------------------------------------
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=./storage
STORAGE_PUBLIC_URL=/media

# --- CORS (frontend dev server) --------------------------------------------
CORS_ORIGINS=["http://localhost:5173"]
